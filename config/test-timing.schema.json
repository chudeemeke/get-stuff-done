{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 41 test timing baseline",
  "type": "object",
  "required": ["metadata", "platforms"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["capturedAt", "nodeVersion", "bunVersion", "upstreamVersion", "runs"],
      "properties": {
        "capturedAt": { "type": "string", "minLength": 1 },
        "nodeVersion": { "type": "string", "minLength": 1 },
        "bunVersion": { "type": "string", "minLength": 1 },
        "upstreamVersion": { "type": "string", "minLength": 1 },
        "runs": { "type": "integer", "minimum": 1 },
        "source": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "platforms": {
      "type": "object",
      "required": ["linux", "macos", "windows"],
      "properties": {
        "linux": { "$ref": "#/definitions/platformTiming" },
        "macos": { "$ref": "#/definitions/platformTiming" },
        "windows": { "$ref": "#/definitions/platformTiming" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "platformTiming": {
      "type": "object",
      "required": ["total", "files"],
      "properties": {
        "total": { "$ref": "#/definitions/metric" },
        "files": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/definitions/metric" }
        }
      },
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "required": ["mean_ms", "stddev_ms", "min_ms", "max_ms", "samples"],
      "properties": {
        "mean_ms": { "type": "integer", "minimum": 0 },
        "stddev_ms": { "type": "integer", "minimum": 0 },
        "min_ms": { "type": "integer", "minimum": 0 },
        "max_ms": { "type": "integer", "minimum": 0 },
        "samples": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  }
}
