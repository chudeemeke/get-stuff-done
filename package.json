{
  "name": "@chude/get-stuff-done",
  "version": "3.0.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "A meta-prompting, context engineering and spec-driven development system for Claude Code, OpenCode and Gemini. Fork of GSD by TACHES.",
  "bin": {
    "get-stuff-done": "bin/install.js",
    "gsd": "bin/gsd.js"
  },
  "files": [
    "dist",
    "bin",
    "overlay/branding.json",
    "overlay/features.json",
    "scripts/check-overrides.js",
    "scripts/lib/upstream-source.js",
    "scripts/preview-update.js"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "meta-prompting",
    "context-engineering",
    "spec-driven-development",
    "gemini",
    "gemini-cli",
    "mistral-vibe",
    "vibe-cli"
  ],
  "author": "Chude (fork), TACHES (original)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chudeemeke/get-stuff-done.git"
  },
  "homepage": "https://github.com/chudeemeke/get-stuff-done",
  "bugs": {
    "url": "https://github.com/chudeemeke/get-stuff-done/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.197",
    "ajv": "^8.17.1",
    "json5": "^2.2.3",
    "pathe": "^2.0.3"
  },
  "overrides": {
    "fast-uri": "3.1.3",
    "flatted": "3.4.2",
    "hono": "4.12.27",
    "minimatch": "3.1.5"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^3.0.1",
    "@opengsd/gsd-core": "1.5.0",
    "audit-ci": "7.1.0",
    "husky": "^9.1.7",
    "sharp": "^0.34.5"
  },
  "scripts": {
    "prepare": "husky",
    "install": "node bin/install.js",
    "build": "node scripts/build.js",
    "compose": "node scripts/compose.js",
    "finalize-dist": "node scripts/finalize-dist.js",
    "dist": "bun run compose && bun run build && bun run finalize-dist",
    "prepublishOnly": "bun run dist",
    "audit:ci": "node scripts/audit-check.js",
    "bench": "node scripts/bench.js",
    "perf:check": "node scripts/check-perf.js",
    "bench:test-timing": "node scripts/bench-test-timing.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:upstream": "node --test tests/*.test.cjs",
    "preview-update": "node bin/preview-update-cli.js"
  }
}
