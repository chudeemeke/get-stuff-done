# Categorical line-ending policy. Prevents Windows contributors from
# accidentally committing CRLF in files where LF is required for correct
# execution (shell scripts, YAML, JSON, lockfiles).
#
# Default: let git auto-detect text vs binary, normalize text to LF in repo.
* text=auto eol=lf

# Files where LF is non-negotiable (script execution, parser correctness,
# diff stability). Force LF regardless of platform.
*.sh        text eol=lf
*.bash      text eol=lf
*.cjs       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
bun.lock    text eol=lf
package.json text eol=lf
package-lock.json text eol=lf

# Windows-only files that should keep CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files — never line-ending-normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.tgz       binary
*.zip       binary
*.tar.gz    binary
*.gz        binary
