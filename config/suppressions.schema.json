{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Audit suppressions",
  "description": "Structured suppressions for dependency and supply-chain audit findings.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "severity", "reason", "reviewer", "reviewedDate", "reReviewDate"],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "severity": {
        "type": "string",
        "enum": ["low", "moderate", "medium", "high", "critical"]
      },
      "reason": {
        "type": "string",
        "minLength": 1
      },
      "reviewer": {
        "type": "string",
        "minLength": 1
      },
      "reviewedDate": {
        "type": "string",
        "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
      },
      "reReviewDate": {
        "type": "string",
        "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
      }
    },
    "additionalProperties": false
  },
  "additionalProperties": false
}
